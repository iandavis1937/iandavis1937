# Firebase project config — copy public/js/firebase-config.js from this template.
# These values come from: Firebase Console → Project Settings → Your apps → SDK setup
#
# firebase-config.js is gitignored so credentials never enter version control.
# Firebase web config is not secret (it's sent to every browser), but keeping
# it out of git avoids leaking project IDs in public repos and makes it easy
# to swap projects without touching committed files.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
